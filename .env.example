# Phase 1 — Database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Phase 2 — Auth
NEXTAUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"
INVITE_EXPIRY_DAYS=7
MAX_USERS=5

# Phase 3 — SmugMug
SMUGMUG_API_KEY=
SMUGMUG_API_SECRET=
SMUGMUG_ACCESS_TOKEN=
SMUGMUG_ACCESS_SECRET=
SMUGMUG_SITE_PASSWORD=
SMUGMUG_ALBUM_BASE_URL="https://yourname.smugmug.com"

# Phase 4 — AWS Rekognition
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
REKOGNITION_COLLECTION_ID="recall-faces"
GEOCODING_API_KEY=

# Phase 7 — AI Ratings
AI_RATING_API_KEY=
AI_RATING_MODEL="claude-sonnet-4-6"
